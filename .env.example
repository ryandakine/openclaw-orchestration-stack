# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...

# =============================================================================
# ARBITRAGE HUNTER - EXCHANGE/BOOKIE ADAPTER CONFIGURATION
# =============================================================================

# Enable/Disable the arbitrage hunter (default: false)
ARB_HUNTER_ENABLED=false

# Database path for ingestion data (default: data/arb_hunter.db)
ARB_HUNTER_DB_PATH="data/arb_hunter.db"

# Ingestion schedule interval in seconds (default: 3600 = 1 hour)
INGESTION_INTERVAL_SECONDS=3600

# --- Prediction Market Adapters ---

# Polymarket (No API key required for public data)
# POLYMARKET_API_BASE=https://gamma-api.polymarket.com  # Optional: Custom endpoint
# POLYMARKET_TIMEOUT=30                                 # Request timeout in seconds

# Kalshi (API key recommended for higher rate limits)
KALSHI_API_KEY="your_kalshi_api_key_here"
# KALSHI_API_SECRET="your_kalshi_secret_here"          # If using authenticated endpoints
# KALSHI_TIMEOUT=30

# PredictIt (No API key required)
# PREDICTIT_TIMEOUT=30

# --- Sportsbook Adapters (via The Odds API) ---

# The Odds API (Required for sportsbook data)
ODDS_API_KEY="your_odds_api_key_here"                  # Get at https://the-odds-api.com
# SPORTSBOOK_TIMEOUT=30

# Individual Bookmaker Configuration (uses Odds API internally)
DRAFTKINGS_API_KEY="${ODDS_API_KEY}"                   # Uses ODDS_API_KEY
FANDUEL_API_KEY="${ODDS_API_KEY}"                      # Uses ODDS_API_KEY
BET365_API_KEY="${ODDS_API_KEY}"                       # Uses ODDS_API_KEY

# --- Arbitrage Hunter Settings ---

# Thresholds
ARB_MIN_NET_EDGE_PCT=2.0                               # Minimum net edge to alert (%)
ARB_MIN_TOTAL_LIQUIDITY=10000                          # Minimum liquidity in USD
ARB_MAX_STALENESS_SECONDS=120                          # Max age of price data
ARB_MATCH_CONFIDENCE_MIN=0.85                          # Minimum match confidence
ARB_RESOLUTION_CONFIDENCE_MIN=0.90                     # Minimum resolution confidence

# Telegram Alerts
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_chat_id_here"

# --- Rate Limiting (Optional Overrides) ---

# POLYMARKET_RATE_LIMIT=100                              # Requests per minute
# KALSHI_RATE_LIMIT=100
# PREDICTIT_RATE_LIMIT=60
# ODDS_API_RATE_LIMIT=500                                # Monthly limit on free tier