# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here:your_token_suffix

# Chat ID to send alerts to
# Can be a user ID (e.g., 123456789), group ID (negative number), or channel username (e.g., @mychannel)
TELEGRAM_CHAT_ID=your_chat_id_here

# Enable/disable Telegram notifications (default: true)
TELEGRAM_ENABLED=true

# Test mode - prints to console instead of sending to Telegram (default: false)
# Useful for testing without hitting Telegram API
TELEGRAM_TEST_MODE=false

# Minimum profit percentage to trigger alert (default: 0.01 = 1%)
TELEGRAM_MIN_PROFIT_PCT=0.01

# Include detailed information in alerts (default: true)
TELEGRAM_INCLUDE_DETAILS=true

# Directory to store alert history (default: data/alerts/)
TELEGRAM_HISTORY_DIR=

# API Configuration
ODDS_API_KEY=your_odds_api_key_here
POLYMARKET_API_KEY=your_polymarket_api_key_here

# Database
DATABASE_URL=postgresql://user:pass@localhost/openclaw

# Logging
LOG_LEVEL=INFO
