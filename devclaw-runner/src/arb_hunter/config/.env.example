# =============================================================================
# OpenClaw Arbitrage Hunter - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# All sensitive values should be kept secure and never committed to version control
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================

# Runtime environment: development, staging, or production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application version (auto-set during deployment)
APP_VERSION=1.0.0

# =============================================================================
# Database Configuration
# =============================================================================

# Option 1: Full database URL (recommended for production)
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://openclaw:secure_password@localhost:5432/openclaw

# Option 2: Individual connection parameters (used if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openclaw
DB_USER=openclaw
DB_PASSWORD=change_me_in_production

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# Redis Configuration
# =============================================================================

# Option 1: Full Redis URL
# Format: redis://[:password@]host:port/db
# REDIS_URL=redis://:password@localhost:6379/0

# Option 2: Individual connection parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password

# =============================================================================
# API Server Settings
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# =============================================================================
# Arbitrage Engine Settings
# =============================================================================

# Interval between arbitrage scans (seconds)
ARB_SCAN_INTERVAL_SECONDS=5.0

# Maximum concurrent scans
ARB_MAX_CONCURRENT_SCANS=10

# Cache TTL for arbitrage calculations (seconds)
ARB_CACHE_TTL_SECONDS=30

# =============================================================================
# Execution Settings
# =============================================================================

# Dry-run mode: set to false to enable real trading (USE WITH CAUTION)
DRY_RUN=true

# Position size limits (USD)
MAX_POSITION_SIZE_USD=1000.0
MIN_POSITION_SIZE_USD=10.0

# =============================================================================
# Arbitrage Thresholds
# =============================================================================

# Minimum net edge percentage to consider an arbitrage opportunity
THRESHOLD_MIN_NET_EDGE_PCT=2.0

# Minimum liquidity required (USD)
THRESHOLD_MIN_LIQUIDITY=1000.0

# Maximum data staleness (seconds)
THRESHOLD_MAX_STALENESS_SECONDS=60

# Minimum confidence score (0.0 - 1.0)
THRESHOLD_MIN_CONFIDENCE=0.7

# =============================================================================
# Fee Configuration
# =============================================================================

# Polymarket fees (percentage, e.g., 2.0 = 2%)
FEE_POLYMARKET_MAKER=0.0
FEE_POLYMARKET_TAKER=2.0

# Kalshi fees (percentage)
FEE_KALSHI_MAKER=0.0
FEE_KALSHI_TAKER=0.5

# PredictIt fees (percentage)
FEE_PREDICTIT_MAKER=0.0
FEE_PREDICTIT_TAKER=10.0

# Sportsbook vig model (percentage added to implied odds)
SPORTSBOOK_VIG_MODEL=4.5

# Withdrawal fees (flat USD amounts)
WITHDRAWAL_FEE_POLYMARKET=0.0
WITHDRAWAL_FEE_KALSHI=0.0
WITHDRAWAL_FEE_PREDICTIT=5.0

# =============================================================================
# Slippage Configuration
# =============================================================================

# Base slippage in basis points (1 bps = 0.01%)
SLIPPAGE_BASE_BPS=10

# Liquidity factor: slippage increases as liquidity decreases
# Formula: effective_slippage = base_bps + (liquidity_factor / available_liquidity_usd)
SLIPPAGE_LIQUIDITY_FACTOR=10000

# Maximum slippage cap in basis points
SLIPPAGE_MAX_BPS=100

# =============================================================================
# Telegram Notifications
# =============================================================================

# Enable Telegram notifications
TELEGRAM_ENABLED=false

# Telegram Bot Token (get from @BotFather)
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (get from @userinfobot or group chat)
# TELEGRAM_CHAT_ID=your_chat_id_here

# Rate limiting: max messages per minute
TELEGRAM_RATE_LIMIT_PER_MINUTE=20

# Only send alerts for opportunities above this threshold (USD profit)
TELEGRAM_MIN_PROFIT_ALERT=10.0

# =============================================================================
# API Keys
# =============================================================================

# The Odds API key (required for sportsbook odds)
# Get from: https://the-odds-api.com/
# ODDS_API_KEY=your_odds_api_key_here

# Kalshi API credentials (optional)
# Get from: https://kalshi.com/
# KALSHI_API_KEY=your_kalshi_key_here
# KALSHI_API_SECRET=your_kalshi_secret_here

# Polymarket credentials (optional - can use wallet auth instead)
# POLYMARKET_API_KEY=your_polymarket_key_here

# PredictIt credentials (optional)
# PREDICTIT_USERNAME=your_username
# PREDICTIT_PASSWORD=your_password

# =============================================================================
# Feature Flags
# =============================================================================

# Enable specific venues (set to false to disable)
ENABLE_POLYMARKET=true
ENABLE_KALSHI=true
ENABLE_PREDICTIT=true
ENABLE_SPORTSBOOKS=true

# Enable mock data mode (for testing without real APIs)
ENABLE_MOCK_DATA=false

# Enable paper trading (simulate trades without real execution)
ENABLE_PAPER_TRADING=true

# Enable advanced analytics
ENABLE_ADVANCED_ANALYTICS=false

# =============================================================================
# Monitoring & Metrics
# =============================================================================

# Enable Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL_SECONDS=30

# =============================================================================
# Runtime Configuration (Mutable)
# =============================================================================

# Current log level (can be changed at runtime)
RUNTIME_LOG_LEVEL=INFO

# Force dry-run mode regardless of DRY_RUN setting (safety switch)
RUNTIME_FORCE_DRY_RUN=true

# Circuit breaker: pause scanning when true
RUNTIME_PAUSE_SCANNING=false

# =============================================================================
# Security Settings
# =============================================================================

# JWT secret for API authentication (generate a strong random string)
# JWT_SECRET=your_jwt_secret_here_min_32_chars_long

# API key for external service authentication
# API_KEY=your_api_key_here

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# Development/Testing Settings
# =============================================================================

# Enable debug endpoints (dangerous in production!)
DEBUG_ENDPOINTS=false

# Mock delay for API calls (ms) - useful for testing timeout handling
MOCK_API_DELAY_MS=0

# Test mode: don't persist any data
TEST_MODE=false
