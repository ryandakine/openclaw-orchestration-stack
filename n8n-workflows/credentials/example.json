{
  "_description": "n8n Credentials Template for OpenClaw Orchestration Stack",
  "_usage": "Copy this file to credentials.json and fill in your actual values. NEVER commit credentials.json to git!",
  "_note": "These credential names must match the credential names referenced in workflow JSON files",
  
  "sqlite-credentials": {
    "name": "SQLite Database",
    "type": "sqlite",
    "data": {
      "database": "/home/ryan/openclaw-orchestration-stack/data/openclaw.db"
    }
  },

  "slack-credentials": {
    "name": "Slack API",
    "type": "slackApi",
    "data": {
      "accessToken": "xoxb-your-bot-token-here",
      "botName": "OpenClaw Bot",
      "icon": ":robot_face:"
    }
  },

  "discord-credentials": {
    "name": "Discord Webhook",
    "type": "discordWebhook",
    "data": {
      "webhookUrl": "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN"
    }
  },

  "smtp-credentials": {
    "name": "SMTP Server",
    "type": "smtp",
    "data": {
      "host": "smtp.gmail.com",
      "port": 587,
      "secure": false,
      "user": "your-email@gmail.com",
      "password": "your-app-password-or-api-key",
      "from": "openclaw@yourdomain.com"
    }
  },

  "github-credentials": {
    "name": "GitHub API",
    "type": "githubApi",
    "data": {
      "server": "https://api.github.com",
      "user": "your-github-username",
      "accessToken": "ghp_your_personal_access_token"
    }
  },

  "openai-credentials": {
    "name": "OpenAI API",
    "type": "openAiApi",
    "data": {
      "apiKey": "sk-your-openai-api-key",
      "baseUrl": "https://api.openai.com/v1"
    }
  },

  "anthropic-credentials": {
    "name": "Anthropic API",
    "type": "anthropicApi",
    "data": {
      "apiKey": "sk-ant-your-anthropic-api-key"
    }
  },

  "http-basic-auth": {
    "name": "HTTP Basic Auth",
    "type": "httpBasicAuth",
    "data": {
      "user": "api-user",
      "password": "your-api-password"
    }
  },

  "http-header-auth": {
    "name": "HTTP Header Auth",
    "type": "httpHeaderAuth",
    "data": {
      "name": "X-API-Key",
      "value": "your-api-key-here"
    }
  }
}
